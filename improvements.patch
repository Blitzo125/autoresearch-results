+
+def eval_val_sliding(
+    args: Hyperparameters,
+    base_model: nn.Module,
+    rank: int,
+    world_size: int,
+    device: torch.device,
+    val_tokens: Tensor,
+    base_bytes_lut: Tensor,
+    has_leading_space_lut: Tensor,
+    is_boundary_token_lut: Tensor,
+    stride: int | None = None,
+) -> tuple[float, float]:
+    """Sliding-window eval: each scored token has seq_len-stride tokens of prior context.
+
+    Fully vectorized per batch: one forward pass + masked cross_entropy per batch.
+    No torch.compile to avoid Triton cache conflicts with the training compilation.
+    """
+    stride = stride if stride is not None else args.train_seq_len
+    seq_len = args.train_seq_len
+    if stride >= seq_len:
+        stride = seq_len
+    T = val_tokens.numel() - 1
+    # window i: x=val_tokens[i*stride : i*stride+seq_len], y=val_tokens[i*stride+1 : +seq_len+1]
+    # window 0 scores all seq_len positions; windows i>0 score last `stride` positions.
+    num_windows = (T - seq_len) // stride + 1
+    win_start = (num_windows * rank) // world_size
+    win_end = (num_windows * (rank + 1)) // world_size
+    val_loss_sum = torch.zeros((), device=device, dtype=torch.float64)
+    val_token_count = torch.zeros((), device=device, dtype=torch.float64)
+    val_byte_count = torch.zeros((), device=device, dtype=torch.float64)
+    batch_windows = max(1, args.val_batch_size // (world_size * seq_len))
+    base_model.eval()
+    with torch.inference_mode():
+        for batch_start in range(win_start, win_end, batch_windows):
+            batch_end = min(batch_start + batch_windows, win_end)
+            wins = range(batch_start, batch_end)
+            B = batch_end - batch_start
+            x = torch.stack([val_tokens[w * stride : w * stride + seq_len].to(device=device, dtype=torch.int64) for w in wins])
+            y = torch.stack([val_tokens[w * stride + 1 : w * stride + seq_len + 1].to(device=device, dtype=torch.int64) for w in wins])
+            with torch.autocast(device_type="cuda", dtype=torch.bfloat16):
+                logits = base_model._forward_logits(x)  # (B, seq_len, V)
+            # Build boolean score mask: which positions contribute to the metric.
+            score_mask = torch.zeros(B, seq_len, device=device, dtype=torch.bool)
+            if wins[0] == 0:
+                score_mask[0, :] = True               # window 0: all positions
+                score_mask[1:, seq_len - stride:] = True
+            else:
+                score_mask[:, seq_len - stride:] = True
+            # Vectorized loss.
+            V = logits.size(-1)
+            per_tok_loss = F.cross_entropy(logits.reshape(-1, V).float(), y.reshape(-1), reduction="none").reshape(B, seq_len)
+            val_loss_sum += (per_tok_loss * score_mask).sum().detach().to(torch.float64)
+            val_token_count += score_mask.sum().to(torch.float64)
+            # Byte count.
+            tgt_ids = y[score_mask]
+            prev_ids = x[score_mask]
+            token_bytes = base_bytes_lut[tgt_ids].to(dtype=torch.int16)
+            token_bytes += (has_leading_space_lut[tgt_ids] & ~is_boundary_token_lut[prev_ids]).to(dtype=torch.int16)
+            val_byte_count += token_bytes.to(torch.float64).sum()
+    base_model.train()
+    if dist.is_available() and dist.is_initialized():
+        dist.all_reduce(val_loss_sum, op=dist.ReduceOp.SUM)
+        dist.all_reduce(val_token_count, op=dist.ReduceOp.SUM)
+        dist.all_reduce(val_byte_count, op=dist.ReduceOp.SUM)
+    val_loss = (val_loss_sum / val_token_count).item()
+    bits_per_token = val_loss / math.log(2.0)
+    tokens_per_byte = (val_token_count / val_byte_count).item()
+    return float(val_loss), float(bits_per_token * tokens_per_byte)
+
